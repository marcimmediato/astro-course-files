---
import '../styles/global.css'
import Link from "../components/Link.astro";

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>{title}</title>
</head>
<body>
  <nav>
    <Link href="/">Home</Link>
    <Link href="/about">About</Link>
  </nav>
  <main>
	<slot />
  </main>
</body>
</html>
